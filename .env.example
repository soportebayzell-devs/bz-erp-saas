APP_NAME="Bayzell ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bayzell_erp
DB_USERNAME=bayzell
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@youracademy.com"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=bayzell-erp
AWS_ENDPOINT=          # Set for MinIO: http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=false

# ERP Config
ERP_DEFAULT_TAX_RATE=0.12        # Guatemala IVA 12%
ERP_DEFAULT_CURRENCY=GTQ
ERP_DEFAULT_TIMEZONE=America/Guatemala
ERP_INVOICE_PREFIX=INV
ERP_OVERDUE_REMINDER_DAYS=3

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# Horizon
HORIZON_BALANCE=auto
HORIZON_MAX_PROCESSES=10
