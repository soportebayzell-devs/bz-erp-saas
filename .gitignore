# Keep these directories but not their contents
!/storage/framework/cache/data/.gitkeep
!/storage/framework/sessions/.gitkeep
!/storage/framework/views/.gitkeep
!/storage/logs/.gitkeep

# NOTE: composer.lock IS committed intentionally.
# It ensures reproducible builds on EasyPanel.
# Never add composer.lock to .gitignore.
